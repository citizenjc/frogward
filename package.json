{
  "name": "frogward",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Initial scaffold for SAPO webmail forwarding automation",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx -e \"console.log('frogward scaffold ready')\"",
    "check": "npm run lint && npm run typecheck && npm run test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "pw:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.2",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
